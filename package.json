{
  "name": "sportio-whatsapp",
  "version": "1.0.0",
  "private": true,
  "description": "Sportio - Plataforma esportiva 100% WhatsApp-First",
  "scripts": {
    "dev": "npx tsx --watch src/whatsapp/server.ts",
    "start": "npx tsx src/whatsapp/server.ts",
    "build": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "npx tsx src/server/db/seed.ts",
    "db:setup": "drizzle-kit push && npx tsx src/server/db/seed.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@types/bcryptjs": "^3.0.0",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "stripe": "^17.7.0",
    "superjson": "^2.2.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "undici": "^7.22.0"
  }
}
