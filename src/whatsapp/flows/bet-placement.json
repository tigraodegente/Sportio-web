{
  "version": "4.0",
  "screens": [
    {
      "id": "BET_FORM",
      "title": "Fazer Aposta",
      "data": {
        "match_title": { "type": "string", "__example__": "Joao vs Pedro" },
        "tournament_name": { "type": "string", "__example__": "Beach Tennis Open" },
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" }
            }
          },
          "__example__": [
            { "id": "p1", "title": "Joao (1.85x)" },
            { "id": "p2", "title": "Pedro (2.10x)" }
          ]
        },
        "balance": { "type": "string", "__example__": "500 GCoins" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "${data.match_title}"
          },
          {
            "type": "TextBody",
            "text": "${data.tournament_name}\nSeu saldo: ${data.balance}"
          },
          {
            "type": "Dropdown",
            "name": "prediction",
            "label": "Apostar em",
            "required": true,
            "data-source": "${data.options}"
          },
          {
            "type": "TextInput",
            "name": "amount",
            "label": "Valor (GCoins)",
            "required": true,
            "input-type": "number",
            "helper-text": "Minimo: 1 | Maximo: 10.000"
          },
          {
            "type": "Footer",
            "label": "Confirmar Aposta",
            "on-click-action": {
              "name": "complete",
              "payload": {
                "prediction": "${form.prediction}",
                "amount": "${form.amount}"
              }
            }
          }
        ]
      }
    }
  ]
}
